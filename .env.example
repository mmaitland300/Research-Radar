# Copy to `.env` and set real values. See README "Required env vars".

# Postgres (use DATABASE_URL or standard PG* variables)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/research_radar

# OpenAlex (required for bootstrap / ingest)
OPENALEX_MAILTO=you@example.com

# Embeddings (required for embed-works and similar)
OPENAI_API_KEY=sk-your-key-here

# Web + API wiring (optional; local defaults shown)
# API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: pin Similar papers in the web UI to an embedding set you have materialized
# NEXT_PUBLIC_EMBEDDING_VERSION=v1-title-abstract-1536

# Optional: OpenAI-compatible endpoint (defaults to api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com/v1
